# 环境变量配置

# ===== Tushare 数据源 (统一) =====
TUSHARE_TOKEN=<your_tushare_token>

# ===== Tushare MCP Server =====
TUSHARE_MCP_URL=https://api.tushare.pro/mcp/token=<your_tushare_token>

# ===== 飞书应用机器人 (API方式，无需Webhook) =====
FEISHU_APP_ID=<your_feishu_app_id>
FEISHU_APP_SECRET=<your_feishu_app_secret>
FEISHU_CHAT_ID_SIGNAL=<signal_group_chat_id>
FEISHU_CHAT_ID_REPORT=<review_group_chat_id>  # 可与信号群相同

# ===== 通用 =====
TZ=Asia/Shanghai